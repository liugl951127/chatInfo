# =============================================================================
# online-chat .env.example - 复制为 .env 后再修改
# 复制:  cp .env.example .env
# =============================================================================

# -------- 时间 / JVM --------
TZ=Asia/Shanghai
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC

# -------- 数据库 (mariadb) --------
MARIADB_ROOT_PASSWORD=rootpass_2026
MARIADB_DATABASE=online_chat
MARIADB_USER=chatuser
MARIADB_PASSWORD=chatpass_2026
MARIADB_PORT=3306

# -------- Redis --------
REDIS_PASSWORD=
REDIS_PORT=6379

# -------- 微服务端口 (主机侧) --------
# standalone 默认端口: cs-xxx -> 8081-8089, gateway -> 9000
PORT_AUTH=8081
PORT_IM=8082
PORT_CDP=8083
PORT_COMMUNITY=8084
PORT_PREDICTION=8085
PORT_CUSTOMER_SUCCESS=8086
PORT_AI=8087
PORT_VIDEO=8088
PORT_VOICE=8089
PORT_GATEWAY=9000
PORT_FRONTEND=80

# -------- JWT 共享密钥 (HS256, ≥ 32 字节) --------
# 重要: 所有微服务必须使用同一密钥, 否则 token 校验失败
JWT_SECRET=5vQeSUDLFEt81MPAmQetxV7i8fBJLTSjPCf15seKgOI7PTXou5vgcc4M01aoseUJ
JWT_TTL_MS=86400000

# -------- M3 Adapter (Python 可选) --------
# m3-adapter 提供 AI 推理 HTTP API, 不启用也不影响其他服务启动
M3_ADAPTER_URL=http://m3-adapter:8084
M3_DEFAULT_MODEL=minimax3

# -------- 前端 --------
VITE_API_BASE=/api
BACKEND_GATEWAY_URL=http://cs-gateway

# -------- V3 SLA 监控 + 智能告警 --------
# 告警总开关 (true/false). 关闭时仅控制台打印
ALERT_ENABLED=false

# 通用 webhook (自建 / AlertManager)
ALERT_WEBHOOK_URL=

# PagerDuty Events API v2 routing key
PAGERDUTY_KEY=

# 钉钉机器人 webhook (P0/P1 用)
DINGTALK_WEBHOOK=

# 飞书机器人 webhook
FEISHU_WEBHOOK=

# AlertManager 邮件 (P0 接收人邮箱)
ALERT_EMAIL_TO=sre-oncall@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=alert@example.com
SMTP_PASSWORD=

# Grafana 管理员
GRAFANA_PASSWORD=admin
